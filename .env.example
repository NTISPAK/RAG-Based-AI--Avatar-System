# NTIS AI Avatar - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================
# REQUIRED
# ============================

# Google Gemini API Key (for RAG LLM responses)
# Get one at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Qdrant Vector Database URL
# Local Docker: http://localhost:6333
QDRANT_URL=http://localhost:6333

# Qdrant Collection Name
COLLECTION_NAME=policy_docs

# ============================
# AVATAR SERVER
# ============================

# URL the avatar server uses to reach the RAG backend
RAG_BACKEND_URL=http://127.0.0.1:8000

# Chat language: en (English) or ur (Urdu)
CHAT_LANGUAGE=en

# ============================
# OPTIONAL / ALTERNATIVE TTS
# ============================
# These are only needed if you use the corresponding TTS provider.
# Default (edge-tts) works with no API key.

# Azure Speech (for AzureTTS provider)
# AZURE_SPEECH_KEY=your_azure_speech_key
# AZURE_TTS_REGION=eastus

# Tencent TTS
# TENCENT_APPID=your_appid
# TENCENT_SECRET_ID=your_secret_id
# TENCENT_SECRET_KEY=your_secret_key

# Doubao (Volcano Engine) TTS
# DOUBAO_APPID=your_appid
# DOUBAO_TOKEN=your_token
