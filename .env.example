# NTIS Policy RAG Chatbot - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Google Gemini API Key
# Get yours from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Qdrant Vector Database URL
# Local: http://localhost:6333
# Cloud: https://your-cluster.qdrant.io
QDRANT_URL=http://localhost:6333

# Qdrant Collection Name
COLLECTION_NAME=policy_docs

# Frontend origin (Vite dev server)
FRONTEND_ORIGIN=http://localhost:5173

# Translation Settings
# Enable/disable translation layer (true/false)
ENABLE_TRANSLATION=true

# Default language for chat (en=English, ur=Urdu)
DEFAULT_LANGUAGE=en

# Supported languages (comma-separated)
SUPPORTED_LANGUAGES=en,ur

# LiveTalking language setting (en=English, ur=Urdu)
CHAT_LANGUAGE=en
